FROM mcr.microsoft.com/dotnet/sdk:7.0-alpine@sha256:c6d4c3b82c2979ffd40c8382abd918e2edc1222658db98344be55025147091f9

# Installa Dalamud dalla ultima release stable
ENV DALAMUD_HOME=/lib/dalamud
WORKDIR ${DALAMUD_HOME}
RUN wget -O dalamud.zip https://goatcorp.github.io/dalamud-distrib/latest.zip
RUN unzip dalamud.zip
RUN rm dalamud.zip

# Torna alla directory di Default
WORKDIR /
